<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════════════════╗
  ║  BEFORE STORE SUBMISSION — update these two Identity attributes:            ║
  ║                                                                              ║
  ║  Identity Name      → "Package/Identity/Name" from Partner Center           ║
  ║                        Apps ▸ [Your App] ▸ App identity                     ║
  ║  Identity Publisher → "Package/Identity/Publisher" from Partner Center      ║
  ║                        (format: CN=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX)    ║
  ║                                                                              ║
  ║  Leave Version as-is; bump it for each Store update.                        ║
  ╚══════════════════════════════════════════════════════════════════════════════╝
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
    xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap3 desktop rescap">

    <!--
      ProcessorArchitecture is NOT set here; MSBuild injects it per platform target
      (x86 / x64 / arm64) so the same manifest is shared across all builds.
    -->
    <Identity
        Name="ZacharyMilot.DirectX3DViewer_7q4r7fkq38yhj"
        Publisher="CN=F0883D38-E311-40FA-A25A-1438D43C6323"
        Version="1.0.0.0" />

    <Properties>
        <DisplayName>DirectX 3D Viewer</DisplayName>
        <PublisherDisplayName>Zachary Milot</PublisherDisplayName>
        <Logo>Assets\StoreLogo.png</Logo>
    </Properties>

    <Dependencies>
        <TargetDeviceFamily Name="Windows.Desktop"
                            MinVersion="10.0.17763.0"
                            MaxVersionTested="10.0.26100.0" />
        <!--
          The Microsoft.WindowsAppRuntime.x.y framework package dependency
          is AUTOMATICALLY INJECTED by the Microsoft.WindowsAppSDK NuGet
          package during the build. Do NOT add it manually here.
        -->
    </Dependencies>

    <Resources>
        <Resource Language="en-US" />
        <Resource uap:Scale="100" />
        <Resource uap:Scale="125" />
        <Resource uap:Scale="150" />
        <Resource uap:Scale="200" />
        <Resource uap:Scale="400" />
    </Resources>

    <Applications>
        <Application Id="App"
                     Executable="$targetnametoken$.exe"
                     EntryPoint="$targetentrypoint$">

            <uap:VisualElements
                DisplayName="DirectX 3D Viewer"
                Description="Open, inspect and convert 3D model files — .x  .hxx  .obj  .stl"
                BackgroundColor="transparent"
                Square150x150Logo="Assets\Square150x150Logo.png"
                Square44x44Logo="Assets\Square44x44Logo.png">

                <uap:DefaultTile
                    Wide310x150Logo="Assets\Wide310x150Logo.png"
                    Square71x71Logo="Assets\SmallTile.png"
                    Square310x310Logo="Assets\LargeTile.png"
                    ShortName="3D Viewer">
                    <uap:ShowNameOnTiles>
                        <uap:ShowOn Tile="square150x150Logo" />
                        <uap:ShowOn Tile="wide310x150Logo" />
                        <uap:ShowOn Tile="square310x310Logo" />
                    </uap:ShowNameOnTiles>
                </uap:DefaultTile>

                <!--
                  SplashScreen.png (620×300) is generated by store\generate_msix_assets.ps1.
                  BackgroundColor is shown immediately while the image loads.
                -->
                <uap:SplashScreen Image="Assets\SplashScreen.png"
                                  BackgroundColor="#0D1B2A" />

            </uap:VisualElements>

            <Extensions>

                <!-- File type associations: .x .hxx .obj .stl -->
                <uap:Extension Category="windows.fileTypeAssociation">
                    <uap:FileTypeAssociation Name="dx-model">
                        <uap:DisplayName>3D Model</uap:DisplayName>
                        <uap:InfoTip>Open with DirectX 3D Viewer</uap:InfoTip>
                        <uap:Logo>Assets\Square44x44Logo.png</uap:Logo>
                        <uap:SupportedFileTypes>
                            <uap:FileType>.x</uap:FileType>
                            <uap:FileType>.hxx</uap:FileType>
                            <uap:FileType>.obj</uap:FileType>
                            <uap:FileType>.stl</uap:FileType>
                        </uap:SupportedFileTypes>
                    </uap:FileTypeAssociation>
                </uap:Extension>

                <!-- App Execution Alias (CLI)
                     Installs a stub at:
                       %LOCALAPPDATA%\Microsoft\WindowsApps\dx3dviewer.exe

                     This makes the converter available from any terminal after
                     the app is installed from the Store, with no PATH changes:

                       dx3dviewer.exe convert model.obj output.x
                       dx3dviewer.exe convert tank.stl tank.glb
                       dx3dviewer.exe -help

                     The app detects CLI arguments in App.xaml.cs and handles
                     them headlessly, writing to the console via AttachConsole.
                -->
                <uap3:Extension Category="windows.appExecutionAlias"
                                EntryPoint="Windows.FullTrustApplication">
                    <uap3:AppExecutionAlias>
                        <desktop:ExecutionAlias Alias="dx3dviewer.exe" />
                    </uap3:AppExecutionAlias>
                </uap3:Extension>

            </Extensions>
        </Application>
    </Applications>

    <Capabilities>
        <!--
          runFullTrust is required for WinUI 3 desktop apps and allows the app to:
            • Write to %APPDATA% (settings, logs)
            • Use AllocConsole / AttachConsole for CLI output
            • Open files anywhere on the file system via the file picker
        -->
        <rescap:Capability Name="runFullTrust" />
    </Capabilities>

</Package>
