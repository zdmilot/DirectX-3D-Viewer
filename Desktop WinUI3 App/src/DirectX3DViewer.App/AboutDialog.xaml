            <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="14"
                        Background="#22FFFFFF" Padding="6">
                    <Viewbox>
                        <Path Width="120" Height="120" Stretch="Uniform" Fill="#F2FFFFFF"
                              RenderTransformOrigin="0.5,0.5"
                              Data="F0 M50.5 32.8L73.8 33.2L79.8 33.9L81.4 34.5L82.0 35.0L82.1 35.7L82.6 36.3L85.0 38.1L87.8 40.9L89.9 44.3L90.8 44.4L95.0 46.5L98.2 49.2L100.0 51.4L101.4 54.3L104.4 64.1L105.6 67.1L107.3 70.0L109.8 72.4L115.4 75.5L104.9 75.2L103.1 74.5L100.9 72.4L100.1 71.2L99.3 69.6L97.4 63.9L95.3 60.6L93.6 59.2L91.5 58.1L89.4 57.7L88.9 58.0L85.2 67.7L81.7 74.9L80.4 75.9L73.9 75.9L70.4 76.6L68.3 76.8L62.3 77.9L59.6 79.1L59.1 79.9L59.1 80.6L62.3 85.0L62.2 85.9L60.9 86.6L56.1 87.0L53.2 86.8L51.3 86.6L50.3 86.1L49.9 85.7L49.9 85.0L50.5 83.9L52.7 81.4L53.2 80.6L53.2 79.9L52.6 79.1L49.9 77.9L38.3 75.9L31.9 75.9L30.6 74.9L28.9 71.6L15.9 71.4L10.9 70.7L7.0 69.3L5.6 68.0L4.7 66.2L4.3 64.7L4.5 61.5L5.4 58.2L6.6 56.0L8.6 53.2L11.1 50.6L17.0 46.4L22.9 43.5L24.5 40.9L26.8 38.6L29.5 36.4L30.1 35.7L30.4 34.9L31.5 34.1L38.6 33.2L50.5 32.8Z M21.6 48.5L21.6 50.9L22.1 54.3L23.0 57.3L24.8 62.7L27.0 67.6L16.4 67.5L13.1 67.0L10.9 66.1L10.2 65.5L9.8 64.8L9.7 62.8L10.3 60.4L12.4 56.1L14.8 53.2L16.2 51.9L19.7 49.3L21.6 48.5Z">
                            <Path.RenderTransform>
                                <ScaleTransform ScaleX="-1" ScaleY="-1" />
                            </Path.RenderTransform>
                        </Path>
                    </Viewbox>
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="DirectX 3D Viewer" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="DirectX 3D File Viewer &amp; Converter" FontSize="12"
                               Foreground="#B3FFFFFF" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Spacing="14" Padding="20,16,20,18">
            <Grid ColumnSpacing="12" RowSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"
                           Foreground="{ThemeResource TextMutedBrush}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="1.0.0" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Author"
                           Foreground="{ThemeResource TextMutedBrush}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Zachary Milot" />
            </Grid>

            <TextBlock Text="Native WinUI 3 / Windows App SDK &#x00B7; Direct3D 11 viewport"
                       FontSize="11" Foreground="{ThemeResource TextMutedBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
