   retVal = dev.GetSequenceRef(sortedName, sortedSequence);

   sortedSequence.SetCurrentPosition(1);
   cnt = sortedSequence.GetCount();
   pos = sortedSequence.GetCurrentPosition();
   Trace("SortSequence3::Sorted sequence ", sortedName, ", count = ", cnt, ", position = ", pos);

   #ifdef _DEBUG 
   TrcTraceSequence(sortedSequence);
   #endif
   return(retVal);

}

// sort iSequence for replicas 
//

// sort replicates for pipetting by sample
// i.e. samples A,B.C will replicate as AAA..,BBB..,CCC
// sortedSequence will contain ( repCnt * each sample ) in sequence
function SortSequenceForRepsBySample(device& dev, sequence iSequence, variable repCnt, variable sampleCount, variable tipCount, sequence& sortedSequence)
{
   variable i(0);
   variable j(0);
   variable total(0);
   variable count(0);
   variable xferCnt(0);
   variable remaining(0);
   variable sample(0);
   variable L_id;
   variable P_id;
   sequence iSequenceCopy;
   sequence iSequenceOut;

   Trace("SortSequenceForRepsBySample()");

   total = 0;//repCnt * sampleCount;  
   remaining = sampleCount;
   xferCnt = tipCount;

   iSequenceCopy.CopySequence( iSequence);
   iSequenceCopy.SetCurrentPosition(1);

   
   while ( total < (sampleCount*repCnt) )
   {
      if ( remaining < tipCount ) xferCnt = remaining;
      for (i=1; i<=repCnt; i++) 
      {
         iSequenceCopy.SetCurrentPosition(total+i);
         for (j=1; j <=xferCnt; j++) 
         {
            L_id = iSequenceCopy.GetLabwareId();
            P_id = iSequenceCopy.GetPositionId();
            iSequenceOut.Add( L_id, P_id, dev );
            iSequenceCopy.Increment(repCnt);
         }
      }
      total = total + (repCnt*xferCnt);
      remaining = remaining - xferCnt;
   }

   sortedSequence.CopySequence(iSequenceOut);
   sortedSequence.SetCurrentPosition(1);

   #ifdef _DEBUG 
   TrcTraceSequence(sortedSequence);
   #endif
}

// sort replicates for pipetting by interleaving sample
// i.e. samples A,B.C will replicate as ABC..,ABC..,ABC
// sortedSequence will contain (samples) * repCnt

function SortSequenceForRepsByInterleave(device& dev, sequence iSequence, variable repCnt, variable sampleCount, variable tipCount, sequence& sortedSequence)
{
   variable i(0);
   variable j(0);
   variable total(0);
   variable count(0);
   variable xferCnt(0);
   variable remaining(0);
   variable L_id;
   variable P_id;
   variable ix(0);
   sequence iSequenceCopy;
   sequence iSequenceInterleave;
   variable pos(0);

   Trace("SortSequenceForRepsByInterleave()");

   total = repCnt * sampleCount;  
   remaining = sampleCount;
   xferCnt = tipCount;

   iSequenceCopy.CopySequence( iSequence);
   iSequenceCopy.SetCurrentPosition(1);

// sort for transfer of maximum number of samples * repCnt (to support reuse of tips)
   while ( count < total )
   {
      if ( remaining < tipCount) xferCnt = remaining;
      
      for (i=1; i<=repCnt; i++) 
      {
         pos = iSequenceCopy.GetCurrentPosition();

         for (j=1; j <=xferCnt; j++) 
         {
            L_id = iSequenceCopy.GetLabwareId();
            P_id = iSequenceCopy.GetPositionId();
            iSequenceInterleave.Add( L_id, P_id, dev );
            iSequenceCopy.Increment(1);
            count++;
         }
          
         iSequenceCopy.SetCurrentPosition(pos + sampleCount);  // next rep for samples
            
      }
      
      remaining = remaining - xferCnt;

      // reset iSequenceCopy position for remaining samples
      ix++;
      iSequenceCopy.SetCurrentPosition((ix*xferCnt)+1);
   }

   // assign sortedSequence
   sortedSequence.CopySequence(iSequenceInterleave);
   sortedSequence.SetCurrentPosition(1);

   #ifdef _DEBUG 
   TrcTraceSequence(sortedSequence);
   #endif
}



function FindPositionIndex(variable labwareId, variable positionId, variable labwareIds[], variable positionIds[])
{
   variable ix;
   variable L_id;
   variable P_id;

   for(ix =0; ix< positionIds.GetSize(); ix++)
   {
      P_id = positionIds.GetAt(ix);
      if ( P_id == positionId )
      {
         L_id = labwareIds.GetAt(ix);
         if ( L_id == labwareId)
            return (ix);
      }
   }
   return (-1);   // no match
}

function LookupMatchingIndexId(variable lookupMatchedIndexId, variable lookupFromMatchedIndexIds[],  variable lookedIntoMatchedIndexIds[])
{
   variable ix;
   variable lookupFromMatchedIndexId;
   variable matchingIndexId;
   variable foundPos(-1);

   for(ix =0; ix< lookupFromMatchedIndexIds.GetSize(); ix++)
   {
      lookupFromMatchedIndexId = lookupFromMatchedIndexIds.GetAt(ix);
      if ( lookupFromMatchedIndexId == lookupMatchedIndexId )
      {
         foundPos = ix;
         break;
      }
   }

   if(foundPos != -1)
   {
      matchingIndexId = lookedIntoMatchedIndexIds.GetAt(foundPos);
      return(matchingIndexId);
   }
 
   return (-1);   // no match
}

function ext_SortSequence2BySequenceOrder(sequence iSequence, variable lookupFromLabwareIds[], variable lookupFromPositionIds[], variable lookedIntoLabwareIds[], variable lookedIntoPositionIds[], sequence& iSequence2, variable lookupFromMatchedIndexIds[],  variable lookedIntoMatchedIndexIds[])
{ 
   sequence sortedSequence;
   variable L_id;
   variable P_id;
   variable pos;
   variable index;
   variable matchingIndexId;

   if(iSequence.GetCount() > 0 && iSequence2.GetCount() > 0)
   {
       iSequence.SetCurrentPosition(1);

       for (pos = 1; pos>0 && pos <= iSequence.GetCount(); pos = iSequence.Increment(1))
       {
          L_id = iSequence.GetLabwareId();
          P_id = iSequence.GetPositionId();

          index = FindPositionIndex(L_id, P_id, lookupFromLabwareIds, lookupFromPositionIds);
          if ( index == -1 ) return (0);

          matchingIndexId = LookupMatchingIndexId(index, lookupFromMatchedIndexIds, lookedIntoMatchedIndexIds);
          if(matchingIndexId == -1) return(0);

          L_id = lookedIntoLabwareIds.GetAt(matchingIndexId);
          P_id = lookedIntoPositionIds.GetAt(matchingIndexId);
      
          sortedSequence.Add( L_id, P_id);
       } 

       iSequence2.CopySequence(sortedSequence);

       iSequence2.SetCurrentPosition(1);
   }

   #ifdef _DEBUG 
   TrcTraceSequence(sortedSequence);
   #endif

   return(0); 
}

function SortVolumes(variable matchedSourceOrTargetIndices[], variable volumeValues[], variable sortedVolumeValues[])
{ 
   variable lastMin(-1);
   variable min;
   variable minIndex(0);
   variable currValue;
   variable sortedIndices[];
   variable _ix;
   variable _iy;
   variable cntOfMatchedSourceOrTargetIndices;

   cntOfMatchedSourceOrTargetIndices = matchedSourceOrTargetIndices.GetSize();
   if(cntOfMatchedSourceOrTargetIndices == 0)
      return;

   sortedVolumeValues.SetSize(0);
  
   min = matchedSourceOrTargetIndices.GetAt(0);
   
   for(_ix = 0; _ix < cntOfMatchedSourceOrTargetIndices; _ix++)          
   {
      if(matchedSourceOrTargetIndices.GetAt(_ix) != -1)
      {
	      for(_iy = 0; _iy < cntOfMatchedSourceOrTargetIndices; _iy++)
	      {   
             if(matchedSourceOrTargetIndices.GetAt(_iy) != -1)
             {
                 currValue = matchedSourceOrTargetIndices.GetAt(_iy);
		         if(currValue > lastMin)
		         {
		            if(min == lastMin)
		            {
			           min = currValue;
			           minIndex = _iy;
			        }
			        else
			        {
			           if(currValue < min)
		               {
				          min = currValue;
				          minIndex = _iy;
			           }
			        }
		         }
             }
          }
	      sortedIndices.AddAsLast(minIndex);
	      lastMin = min;
      }
   }
   
   if(sortedIndices.GetSize() > 0)
   {
       for(_ix=0; _ix < sortedIndices.GetSize(); _ix++)
       {
          sortedVolumeValues.AddAsLast(volumeValues.GetAt(sortedIndices.GetAt(_ix)));
       }
   }
   
   return(0); 
}

// SortSequence2BySequenceOrder()
// labwareIds[] and positionIds[] contains the original iSequence order
// iSequence is the sorted sequence that contains all positions in labwareIds[] and positionIds[]
// >> sort iSequence2 in the same sort order
//
function SortSequence2BySequenceOrder(sequence iSequence, variable labwareIds[], variable positionIds[], sequence& iSequence2)
{ 
   sequence sortedSequence;
   variable L_id;
   variable P_id;
   variable pos;
   variable index;

   iSequence.SetCurrentPosition(1);

   for (pos = 1; pos>0 && pos <= iSequence.GetCount(); pos = iSequence.Increment(1))
   {
      L_id = iSequence.GetLabwareId();
      P_id = iSequence.GetPositionId();

      index = FindPositionIndex(L_id, P_id, labwareIds, positionIds);
      if ( index == -1 ) return (0);

      iSequence2.SetCurrentPosition( index+1 );
      L_id = iSequence2.GetLabwareId();
      P_id = iSequence2.GetPositionId();     
      
      sortedSequence.Add( L_id, P_id);
   } 

   iSequence2.CopySequence(sortedSequence);


   #ifdef _DEBUG 
   TrcTraceSequence(sortedSequence);
   #endif

   return(0); 
}




