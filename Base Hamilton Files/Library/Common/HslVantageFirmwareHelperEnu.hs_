function StringTable()
{
    Insert(VantageFirmwareHelper::parseFirmwareCommandFailed,        "Interpretation of firmware command result <%s1> failed. Parameter <%s2> not found");
    Insert(VantageFirmwareHelper::firmwareCommandFailed,             "Firmware command <%s1> with parameter <%s2> failed! - return value <%s3>");
}
