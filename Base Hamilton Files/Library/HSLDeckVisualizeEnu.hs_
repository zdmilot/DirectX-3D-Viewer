// This is the language dependant part of the HslDeckVisualize hsl library

function StringTable()
{
	Insert(IDS::traceSource,				"DeckVisualize");
	Insert(IDS::errDeckLayout, 			"Error: No decklayout?");
	Insert(IDS::errArrayDimensions, 	   "Error: Array dimensions do not match!");
	Insert(IDS::errInvalidParameter,		"The parameter '%s' is incorrect."		);
}
