<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DirectX3DViewer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ctl="using:DirectX3DViewer.App.Controls"
    mc:Ignorable="d"
    Title="DirectX 3D Viewer">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="3" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============ Custom Title Bar ============ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="14,0,0,0" Spacing="11">
                <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource BrandGradientBrush}"
                        Padding="3">
                    <Viewbox>
                        <Path Width="120" Height="120" Stretch="Uniform"
                              Fill="#E6DCE1E6" RenderTransformOrigin="0.5,0.5"
                              Data="F0 M50.5 32.8L73.8 33.2L79.8 33.9L81.4 34.5L82.0 35.0L82.1 35.7L82.6 36.3L85.0 38.1L87.8 40.9L89.9 44.3L90.8 44.4L95.0 46.5L98.2 49.2L100.0 51.4L101.4 54.3L104.4 64.1L105.6 67.1L107.3 70.0L109.8 72.4L115.4 75.5L104.9 75.2L103.1 74.5L100.9 72.4L100.1 71.2L99.3 69.6L97.4 63.9L95.3 60.6L93.6 59.2L91.5 58.1L89.4 57.7L88.9 58.0L85.2 67.7L81.7 74.9L80.4 75.9L73.9 75.9L70.4 76.6L68.3 76.8L62.3 77.9L59.6 79.1L59.1 79.9L59.1 80.6L62.3 85.0L62.2 85.9L60.9 86.6L56.1 87.0L53.2 86.8L51.3 86.6L50.3 86.1L49.9 85.7L49.9 85.0L50.5 83.9L52.7 81.4L53.2 80.6L53.2 79.9L52.6 79.1L49.9 77.9L38.3 75.9L31.9 75.9L30.6 74.9L28.9 71.6L15.9 71.4L10.9 70.7L7.0 69.3L5.6 68.0L4.7 66.2L4.3 64.7L4.5 61.5L5.4 58.2L6.6 56.0L8.6 53.2L11.1 50.6L17.0 46.4L22.9 43.5L24.5 40.9L26.8 38.6L29.5 36.4L30.1 35.7L30.4 34.9L31.5 34.1L38.6 33.2L50.5 32.8Z M21.6 48.5L21.6 50.9L22.1 54.3L23.0 57.3L24.8 62.7L27.0 67.6L16.4 67.5L13.1 67.0L10.9 66.1L10.2 65.5L9.8 64.8L9.7 62.8L10.3 60.4L12.4 56.1L14.8 53.2L16.2 51.9L19.7 49.3L21.6 48.5Z">
                            <Path.RenderTransform>
                                <ScaleTransform ScaleX="-1" ScaleY="-1" />
                            </Path.RenderTransform>
                        </Path>
                    </Viewbox>
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="0">
                    <TextBlock Text="DirectX 3D Viewer" FontWeight="SemiBold" FontSize="14"
                               Foreground="{ThemeResource TextPrimaryBrush}" />
                    <TextBlock Text="DIRECTX MODEL VIEWER" FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextMutedBrush}"
                               CharacterSpacing="220" />
                </StackPanel>
            </StackPanel>

            <!-- Drag region -->
            <Border Grid.Column="1" Grid.ColumnSpan="2" Background="Transparent" />
        </Grid>

        <!-- Accent tube underline -->
        <Border Grid.Row="1" Background="{StaticResource TubeGradientBrush}" Opacity="0.85" />

        <!-- ============ Viewer Area ============ -->
        <Grid Grid.Row="2" AllowDrop="True"
              DragOver="OnDragOver" Drop="OnDrop" DragLeave="OnDragLeave">

            <!-- Viewport right-click context menu -->
            <Grid.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:Name="CtxScreenshot" Text="Screenshot&#x2026;" Tag="screenshot"
                                    Click="OnContextMenuAction">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE722;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSubItem Text="Export object&#x2026;">
                        <MenuFlyoutSubItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE896;" />
                        </MenuFlyoutSubItem.Icon>
                        <MenuFlyoutItem Text="Export as .X" Tag="x" Click="OnExport" />
                        <MenuFlyoutItem Text="Export as .OBJ" Tag="obj" Click="OnExport" />
                        <MenuFlyoutItem Text="Export as .STL" Tag="stl" Click="OnExport" />
                        <MenuFlyoutItem Text="Export as .GLB" Tag="glb" Click="OnExport" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Reset camera" Tag="reset" Click="OnContextMenuAction">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72C;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Zoom to fit" Tag="fit" Click="OnContextMenuAction">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9A6;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Grid.ContextFlyout>

            <!-- Native D3D viewport -->
            <ctl:D3DViewport x:Name="Viewport" />

            <!-- Empty-state hint -->
            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="14">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8B7;"
                          FontSize="46" Foreground="{ThemeResource TextMutedBrush}" Opacity="0.5"
                          HorizontalAlignment="Center" IsHitTestVisible="False" />
                <TextBlock Text="Open or drop a 3D file to begin"
                           Foreground="{ThemeResource TextMutedBrush}" FontSize="14"
                           HorizontalAlignment="Center" IsHitTestVisible="False" />
                <TextBlock Text=".x  &#x2022;  .hxx  &#x2022;  .obj  &#x2022;  .stl"
                           Foreground="{ThemeResource TextMutedBrush}" FontSize="11"
                           Opacity="0.7" HorizontalAlignment="Center" CharacterSpacing="120"
                           IsHitTestVisible="False" />
                <Button Click="OnOpen" Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center" Height="38" Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8E5;" FontSize="14" />
                        <TextBlock Text="Open file" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Floating toolbar (top-right) -->
            <Border x:Name="FloatingToolbar" VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,16,16,0" CornerRadius="12"
                    Background="{ThemeResource ToolbarBackgroundBrush}"
                    BorderBrush="{ThemeResource ToolbarBorderBrush}" BorderThickness="1"
                    Padding="6">
                <StackPanel Orientation="Vertical" Spacing="2">
                    <Button Style="{StaticResource ToolButtonStyle}" Click="OnResetCamera"
                            ToolTipService.ToolTip="Reset camera">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72C;" FontSize="15" />
                    </Button>
                    <Button Style="{StaticResource ToolButtonStyle}" Click="OnZoomFit"
                            ToolTipService.ToolTip="Zoom to fit">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9A6;" FontSize="15" />
                    </Button>
                    <ToggleButton x:Name="WireframeButton" Style="{StaticResource ToolToggleStyle}"
                                  Click="OnWireframe" ToolTipService.ToolTip="Wireframe">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8A9;" FontSize="15" />
                    </ToggleButton>
                    <Button x:Name="ProjectionButton" Style="{StaticResource ToolButtonStyle}"
                            ToolTipService.ToolTip="Projection mode">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE809;" FontSize="15" />
                        <Button.Flyout>
                            <Flyout Placement="Left">
                                <StackPanel Width="175" Spacing="10">
                                    <TextBlock Text="Projection" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="PROJECTION TYPE" FontSize="10" FontWeight="SemiBold"
                                               CharacterSpacing="160" Foreground="{ThemeResource TextMutedBrush}" />
                                    <RadioButton x:Name="ProjPerspective" Content="Perspective"
                                                 GroupName="ProjGroup" Tag="perspective"
                                                 IsChecked="True" Checked="OnProjectionChanged" />
                                    <RadioButton x:Name="ProjOrthographic" Content="Orthographic"
                                                 GroupName="ProjGroup" Tag="orthographic"
                                                 Checked="OnProjectionChanged" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <ToggleButton x:Name="GridButton" Style="{StaticResource ToolToggleStyle}"
                                  IsChecked="True" Click="OnGrid" ToolTipService.ToolTip="Gridlines">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xF0E2;" FontSize="15" />
                    </ToggleButton>

                    <Rectangle Height="1" Margin="4,3" Fill="{ThemeResource ToolbarBorderBrush}" />

                    <Button Style="{StaticResource ToolButtonStyle}" Click="OnZoomIn"
                            ToolTipService.ToolTip="Zoom in">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8A3;" FontSize="15" />
                    </Button>
                    <Button Style="{StaticResource ToolButtonStyle}" Click="OnZoomOut"
                            ToolTipService.ToolTip="Zoom out">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71F;" FontSize="15" />
                    </Button>
                    <ToggleButton x:Name="PanButton" Style="{StaticResource ToolToggleStyle}"
                                  Click="OnPanMode" ToolTipService.ToolTip="Pan mode">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7C2;" FontSize="15" />
                    </ToggleButton>

                    <Rectangle Height="1" Margin="4,3" Fill="{ThemeResource ToolbarBorderBrush}" />

                    <Button x:Name="TransformButton" Style="{StaticResource ToolButtonStyle}"
                            ToolTipService.ToolTip="Rotate / Mirror">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7AD;" FontSize="15" />
                        <Button.Flyout>
                            <Flyout Placement="Left">
                                <StackPanel Width="220" Spacing="10">
                                    <TextBlock Text="Transform" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="ROTATE &#x00B1;90&#x00B0;" FontSize="10" FontWeight="SemiBold"
                                               CharacterSpacing="160" Foreground="{ThemeResource TextMutedBrush}" />
                                    <Grid ColumnSpacing="6" RowSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch"
                                                Content="X  +90&#x00B0;" Tag="X+" Click="OnRotate" />
                                        <Button Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                                                Content="X  &#x2212;90&#x00B0;" Tag="X-" Click="OnRotate" />
                                        <Button Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch"
                                                Content="Y  +90&#x00B0;" Tag="Y+" Click="OnRotate" />
                                        <Button Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"
                                                Content="Y  &#x2212;90&#x00B0;" Tag="Y-" Click="OnRotate" />
                                        <Button Grid.Row="2" Grid.Column="0" HorizontalAlignment="Stretch"
                                                Content="Z  +90&#x00B0;" Tag="Z+" Click="OnRotate" />
                                        <Button Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch"
                                                Content="Z  &#x2212;90&#x00B0;" Tag="Z-" Click="OnRotate" />
                                    </Grid>
                                    <TextBlock Text="MIRROR / REFLECT" FontSize="10" FontWeight="SemiBold"
                                               CharacterSpacing="160" Foreground="{ThemeResource TextMutedBrush}" />
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" HorizontalAlignment="Stretch" Content="X" Tag="X" Click="OnMirror" />
                                        <Button Grid.Column="1" HorizontalAlignment="Stretch" Content="Y" Tag="Y" Click="OnMirror" />
                                        <Button Grid.Column="2" HorizontalAlignment="Stretch" Content="Z" Tag="Z" Click="OnMirror" />
                                    </Grid>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Rectangle Height="1" Margin="4,3" Fill="{ThemeResource ToolbarBorderBrush}" />

                    <Button x:Name="AppearanceButton" Style="{StaticResource ToolButtonStyle}"
                            ToolTipService.ToolTip="Appearance">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE771;" FontSize="15" />
                        <Button.Flyout>
                            <Flyout Placement="Left">
                                <StackPanel Width="244" Spacing="10">
                                    <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="LOOK" FontSize="10" FontWeight="SemiBold"
                                               CharacterSpacing="160" Foreground="{ThemeResource TextMutedBrush}" />
                                    <RadioButton x:Name="LookDay" Content="Day"
                                                 GroupName="LookGroup" Tag="0"
                                                 IsChecked="True" Checked="OnLookOptionChecked" />
                                    <RadioButton x:Name="LookNight" Content="Night"
                                                 GroupName="LookGroup" Tag="1"
                                                 Checked="OnLookOptionChecked" />
                                    <RadioButton x:Name="LookTransparent" Content="Transparent"
                                                 GroupName="LookGroup" Tag="2"
                                                 Checked="OnLookOptionChecked" />
                                    <TextBlock Text="Transparent removes the backdrop — ideal for PNG screenshots."
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextMutedBrush}" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Style="{StaticResource ToolButtonStyle}" Click="OnHelp"
                            ToolTipService.ToolTip="Help &amp; CLI Reference">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  Glyph="&#xE9CE;" FontSize="15" />
                    </Button>
                    <Button x:Name="AboutButton" Style="{StaticResource ToolButtonStyle}"
                            Click="OnAbout" ToolTipService.ToolTip="About">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  Glyph="&#xE946;" FontSize="15" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- Drop overlay -->
            <Border x:Name="DropOverlay" Visibility="Collapsed"
                    Background="#990D1B2A" BorderBrush="{ThemeResource AccentBrush}"
                    BorderThickness="2" Margin="20" CornerRadius="16">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8E5;"
                              FontSize="48" Foreground="White" />
                    <TextBlock Text="Drop 3D file to open" Foreground="White" FontSize="16"
                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ============ Bottom command bar ============ -->
            <Border VerticalAlignment="Bottom" Height="56"
                    Background="{ThemeResource CommandBarBrush}"
                    BorderBrush="{ThemeResource ToolbarBorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Click="OnOpen" Height="36" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8E5;" FontSize="14" />
                            <TextBlock Text="Open" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Click="OnSaveX" Height="36" Margin="0,0,8,0"
                            IsEnabled="False" x:Name="SaveButton">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>

                    <Rectangle Grid.Column="2" Width="1" Margin="6,12" Fill="{ThemeResource ToolbarBorderBrush}" />

                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="12,0" Spacing="1">
                        <TextBlock x:Name="FilePathText" Text="No file loaded"
                                   Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="CamDisplay"
                                   Text="X: 0.0  Y: 0.0  Z: 0.0  |  Pitch: 0.0&#x00B0;  Yaw: 0.0&#x00B0;"
                                   Foreground="{ThemeResource TextMutedBrush}" FontSize="11"
                                   FontFamily="Consolas" />
                    </StackPanel>

                    <Button Grid.Column="4" Click="OnScreenshot" Height="36" Margin="0,0,8,0"
                            x:Name="ScreenshotButton" IsEnabled="False">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE722;" FontSize="14" />
                            <TextBlock Text="Screenshot" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="5" Height="36" Style="{StaticResource AccentButtonStyle}"
                            x:Name="ExportButton" IsEnabled="False">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE896;" FontSize="14" />
                            <TextBlock Text="Export" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem Text="Export as .X" Tag="x" Click="OnExport" />
                                <MenuFlyoutItem Text="Export as .OBJ" Tag="obj" Click="OnExport" />
                                <MenuFlyoutItem Text="Export as .STL" Tag="stl" Click="OnExport" />
                                <MenuFlyoutItem Text="Export as .GLB" Tag="glb" Click="OnExport" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Border>

            <!-- Busy ring -->
            <ProgressRing x:Name="BusyRing" IsActive="False" Width="46" Height="46"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- ============ Full-window splash overlay ============ -->
        <Grid x:Name="SplashOverlay" Grid.Row="0" Grid.RowSpan="3"
              Background="{StaticResource BrandGradientBrush}" Canvas.ZIndex="99">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                <Viewbox Width="132" Height="132">
                    <Path Stretch="Uniform" Fill="#FFB7DFFF" RenderTransformOrigin="0.5,0.5"
                          Data="F0 M50.5 32.8L73.8 33.2L79.8 33.9L81.4 34.5L82.0 35.0L82.1 35.7L82.6 36.3L85.0 38.1L87.8 40.9L89.9 44.3L90.8 44.4L95.0 46.5L98.2 49.2L100.0 51.4L101.4 54.3L104.4 64.1L105.6 67.1L107.3 70.0L109.8 72.4L115.4 75.5L104.9 75.2L103.1 74.5L100.9 72.4L100.1 71.2L99.3 69.6L97.4 63.9L95.3 60.6L93.6 59.2L91.5 58.1L89.4 57.7L88.9 58.0L85.2 67.7L81.7 74.9L80.4 75.9L73.9 75.9L70.4 76.6L68.3 76.8L62.3 77.9L59.6 79.1L59.1 79.9L59.1 80.6L62.3 85.0L62.2 85.9L60.9 86.6L56.1 87.0L53.2 86.8L51.3 86.6L50.3 86.1L49.9 85.7L49.9 85.0L50.5 83.9L52.7 81.4L53.2 80.6L53.2 79.9L52.6 79.1L49.9 77.9L38.3 75.9L31.9 75.9L30.6 74.9L28.9 71.6L15.9 71.4L10.9 70.7L7.0 69.3L5.6 68.0L4.7 66.2L4.3 64.7L4.5 61.5L5.4 58.2L6.6 56.0L8.6 53.2L11.1 50.6L17.0 46.4L22.9 43.5L24.5 40.9L26.8 38.6L29.5 36.4L30.1 35.7L30.4 34.9L31.5 34.1L38.6 33.2L50.5 32.8Z M21.6 48.5L21.6 50.9L22.1 54.3L23.0 57.3L24.8 62.7L27.0 67.6L16.4 67.5L13.1 67.0L10.9 66.1L10.2 65.5L9.8 64.8L9.7 62.8L10.3 60.4L12.4 56.1L14.8 53.2L16.2 51.9L19.7 49.3L21.6 48.5Z">
                        <Path.RenderTransform>
                            <ScaleTransform ScaleX="-1" ScaleY="-1" />
                        </Path.RenderTransform>
                    </Path>
                </Viewbox>
                <TextBlock Text="DirectX 3D Viewer" FontSize="28" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,0" />
                <TextBlock Text="DIRECTX MODEL VIEWER" FontSize="11" FontWeight="SemiBold"
                           Foreground="#80FFFFFF" CharacterSpacing="280"
                           HorizontalAlignment="Center" Margin="0,0,0,20" />
                <ProgressBar IsIndeterminate="True" Width="170" Height="3"
                             Foreground="#FF00BCD7" Background="#22FFFFFF" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
